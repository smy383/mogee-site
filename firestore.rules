rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'q6XNMYdTxkdAGCvRAA8pxzBwpc72';
    }
    match /portfolio/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'q6XNMYdTxkdAGCvRAA8pxzBwpc72';
    }
  }
}